{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information for freelancers",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "title": { "type": "string" },
        "rate": { "type": "number" },
        "bio": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "name"]
    },
    "Project": {
      "title": "Project",
      "description": "Projects managed by the freelancer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "clientName": { "type": "string" },
        "deadline": { "type": "string" },
        "rate": { "type": "number" },
        "status": { "type": "string", "enum": ["pitching", "active", "completed", "paused"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "clientName", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Incomes and expenses logged by the freelancer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["paid", "unpaid", "pending"] },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "category", "amount", "date", "status"]
    },
    "TimeLog": {
      "title": "TimeLog",
      "description": "Time tracking entries for freelancer tasks",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "projectTitle": { "type": "string" },
        "date": { "type": "string" },
        "hours": { "type": "number" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "projectTitle", "date", "hours"]
    },
    "Client": {
      "title": "Client",
      "description": "Client contact information for freelancer CRM",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "company": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "email", "status"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Stores user profile information, keyed by Firebase UID"
    },
    "projects/{projectId}": {
      "schema": "Project",
      "description": "Stores freelancer projects, secured by owner's userId"
    },
    "transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Stores transaction records (income/expenses) for finance overview"
    },
    "timeLogs/{timeLogId}": {
      "schema": "TimeLog",
      "description": "Stores time tracking logs for billable hour reporting"
    },
    "clients/{clientId}": {
      "schema": "Client",
      "description": "Stores clients contacts CRM data"
    }
  }
}
